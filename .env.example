# ─────────────────────────────────────────────────────────────
# Nodo — variables de REFERENCIA (no se suben valores reales)
# ─────────────────────────────────────────────────────────────
# El panel (frontend) SOLO usa estas dos (públicas, protegidas por RLS):
SUPABASE_URL=https://TU-REF.supabase.co
SUPABASE_ANON_KEY=eyJ...anon...

# ── Los siguientes NUNCA van al frontend ni al repo ──
# Se cargan como secrets de Supabase (Edge Functions) y en Vault:

# App Secret de Meta del canal (para validar la firma del webhook).
# En producción se guarda en Vault por canal; esto es solo referencia local.
META_APP_SECRET=

# Token de acceso (System User) del canal — va en Vault.
META_ACCESS_TOKEN=

# service_role: se usa dentro de Edge Functions (Supabase lo inyecta
# automáticamente como SUPABASE_SERVICE_ROLE_KEY). Nunca en el panel.
